{
  "name": "api",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "vercel-build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=api/index.mjs --packages=external --define:import.meta.main=false",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cheerio": "^1.0.0",
    "@types/node": "^25.3.3",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.25.0",
    "playwright": "^1.58.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "cloudinary": "^2.9.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "postgres": "^3.4.8"
  }
}
